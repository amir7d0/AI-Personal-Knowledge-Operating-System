
# Uncomment and fill in to switch to Supabase:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_PASSWORD=your-db-password

LLM_PROVIDER=openai
LLM_MODEL=meta/llama-3.2-3b-instruct
LLM_API_KEY=your-nvidia-api-key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1
NVIDIA_EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
OPENAI_API_KEY=your-openai-api-key-if-using-openai

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com

# Optional proxy bypass for local / NVIDIA API
# NO_PROXY=localhost,127.0.0.1,::1,integrate.api.nvidia.com
